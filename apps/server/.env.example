# Signaling/SFU server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# mediasoup
# For local dev use 127.0.0.1. On Kubernetes the manifest injects the node IP
# (downward API status.hostIP) into MEDIASOUP_ANNOUNCED_IP.
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40249
MEDIASOUP_NUM_WORKERS=0

# Big-room sharding: when a room's routers are all full, a new router is spun on
# the next worker (up to one router per worker) and producers are piped across.
MAX_PEERS_PER_ROUTER=30

# Redis (Socket.IO adapter) — leave ENABLE_REDIS=false for single-instance local dev
ENABLE_REDIS=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Kafka (event stream) — leave ENABLE_KAFKA=false for local dev without Kafka
ENABLE_KAFKA=false
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=video-call-sfu
KAFKA_EVENTS_TOPIC=call-events

# MongoDB (persists call events + per-room meeting summaries)
ENABLE_MONGO=false
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=videocall
